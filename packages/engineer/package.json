{
  "name": "@x402/engineer",
  "version": "0.1.0",
  "description": "Claude Code skill pack for x402 micropayments on Stellar",
  "type": "module",
  "bin": {
    "x402-engineer": "./dist/cli.js"
  },
  "exports": {
    ".": "./src/index.ts",
